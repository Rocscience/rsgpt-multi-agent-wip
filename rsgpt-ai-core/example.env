# Environment Configuration
# Copy this file to .env and modify the values as needed

# Application Environment (development, production, testing)
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8090
DEBUG=true
UVICORN_WORKERS=1

# Auth0 Configuration (for M2M authentication - BE → AI-Core)
# This validates M2M JWT tokens from rsgpt-be
# AUTH0_AUDIENCE should match the API identifier in Auth0 for rsgpt-ai-core
AUTH0_DOMAIN=dev-example-domain.us.auth0.com
AUTH0_AUDIENCE=rsgpt-ai-core-test-identifier
AUTH0_ALGORITHMS=RS256

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# Security (REQUIRED in production!)
SECRET_KEY=your-secret-key-here-change-in-production

# Logging
LOG_LEVEL=INFO

# LLM API Keys (Required for AI functionality)
# Note: OPENAI_API_KEY is also used for free tracing of non-OpenAI models (Anthropic, etc.)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
PERPLEXITY_API_KEY=your-perplexity-api-key-here
XAI_API_KEY=your-xai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# LLM Configuration
DEFAULT_LLM_PROVIDER=openai

# Pinecone Configuration (Required for context retrieval)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_DEFAULT_TOP_K=20

# RSLog MCP Server Configuration
RSLOG_MCP_URL=https://rslog.example.com/mcp
RSLOG_MCP_TIMEOUT=30

# Reranker Configuration (Optional - for document reranking)
COHERE_API_KEY=your-cohere-api-key-here

# Encryption Configuration (Required for encrypted channels like tech_support)
AES_ENCRYPTOR_KEY=your-base64-fernet-key-here

# Service-to-Service Authentication
# DEVELOPMENT: Static tokens for service authentication (used when ENVIRONMENT=development)
# PRODUCTION: Unused for BE requests - M2M JWT via Auth0 is used instead
# MCP tokens (below) still use static tokens in both dev and prod
BE_SERVICE_TOKEN=your-backend-service-token-minimum-32-chars
# Unified MCP token for all MCP servers (RS2, RSPile, etc.)
MCP_SERVICE_TOKEN=your-mcp-service-token-minimum-32-chars

# Database Configuration
# For PostgreSQL (docker-compose)
DATABASE_URL=postgresql://rsgpt_ai_core_user:rsgpt_ai_core_password@localhost:5433/rsgpt_ai_core_db
