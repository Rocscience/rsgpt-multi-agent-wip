# Environment Configuration
# Copy this file to .env and modify the values as needed

# Application Environment (development, production, testing)
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=true

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# Database Configuration
# For PostgreSQL (docker-compose)
DATABASE_URL=postgresql://rsgpt_user:rsgpt_password@localhost:5432/rsgpt_db

# Auth0 Configuration 
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_AUDIENCE=rsgpt-be-test-identifier

# Auth0 M2M Configuration (for BE -> AI-Core service communication)
# This audience is used to fetch M2M JWT tokens for calling AI-Core in production
# Must match the AUTH0_AUDIENCE in rsgpt-ai-core
AUTH0_AI_CORE_AUDIENCE=rsgpt-ai-core-test-identifier

# RocPortal API Configuration
USER_LICENSE_API_URL=https://api.example.com/users/current-org-licenses
USER_ORG_LICENSE_API_TOKEN=your-license-api-token

# Service Endpoints
AI_CORE_URL=http://localhost:8090

# AI Core Service Authentication
# DEVELOPMENT: Static X-Service-Token for BE -> AI-Core (used when ENVIRONMENT=development)
# PRODUCTION: Unused - M2M JWT via Auth0 is used instead (see AUTH0_AI_CORE_AUDIENCE above)
AI_CORE_SERVICE_TOKEN=your-ai-core-service-token

# Desktop Service Authentication
DESKTOP_SERVICE_TOKEN=your-desktop-service-token-minimum-32-chars

# GitHub Actions Service Authentication
GITHUB_ACTIONS_SERVICE_TOKEN=your-github-actions-service-token-minimum-32-chars

# AWS S3 Configuration (for MCP and Desktop releases storage)
AWS_REGION=us-east-2
MCP_RELEASES_S3_BUCKET=rsinsight-mcp-releases-staging
DESKTOP_RELEASES_S3_BUCKET=rsinsight-desktop-releases-staging

# Admin API Configuration
ADMIN_API_TOKEN=your-admin-api-token-minimum-32-chars

# Logging
LOG_LEVEL=INFO

# RSLog Encryption
RSLOG_ENCRYPTION_KEY=
