# Desktop Application Environment Configuration
# Copy this file to .env and fill in your values

# Auth0 Configuration
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_AUDIENCE=your-auth0-audience

# API Configuration
API_BASE_URL=http://127.0.0.1:8080/api/v1
API_AI_BASE_URL=http://127.0.0.1:8090

# Pinecone Configuration (Optional)
PINECONE_NAMESPACE=your-namespace
PINECONE_INDEX=your-index
PINECONE_TOP_K=10

# Service Authentication Tokens
# NOTE: Service tokens are now fetched automatically from the backend after Auth0 login
# No need to configure these locally - they are managed by the backend's secrets manager
#
# The following tokens are fetched from backend after login:
# - DESKTOP_SERVICE_TOKEN (for desktop-to-backend authentication)
# - MCP_SERVICE_TOKEN (unified token for all MCP servers: RS2, RSPile, etc.)
# - test
