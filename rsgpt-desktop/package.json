{
  "name": "rsinsight-desktop",
  "version": "0.3.2",
  "description": "RSInsight Desktop",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\" --kill-others",
    "dev:renderer": "webpack serve --mode=development",
    "dev:electron": "npm run build:main && npm run build:preload && wait-on http://localhost:5173 && electron .",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc --project tsconfig.main.json",
    "build:preload": "tsc --project tsconfig.preload.json",
    "build:renderer": "webpack --mode=development",
    "build:prod": "npm run build:main && npm run build:preload && webpack --mode=production",
    "build:icons": "electron-icon-builder --input=./build/icon.png --output=./build --flatten",
    "start": "npm run build && electron .",
    "package": "npm run build:prod && electron-builder --publish never",
    "package:mac": "npm run build:prod && electron-builder --mac --publish never",
    "package:win": "npm run build:prod && electron-builder --win --x64 --publish never",
    "package:linux": "npm run build:prod && electron-builder --linux --publish never"
  },
  "keywords": [
    "electron",
    "rsinsight"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1",
    "electron-is-dev": "^3.0.1",
    "events": "^3.3.0",
    "html-webpack-plugin": "^5.6.4",
    "react-refresh": "^0.18.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.3.3",
    "wait-on": "^9.0.1",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "build": {
    "appId": "com.rocscience.rsinsight",
    "productName": "RSInsight Desktop",
    "protocols": [
      {
        "name": "RSInsight Auth Protocol",
        "schemes": [
          "com.rocscience.rsinsight"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "generic",
      "url": "https://rsinsight-desktop-releases-staging.s3.us-east-2.amazonaws.com/rsinsight-desktop/latest"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "build/icons/**/*",
      "python-servers/**/*",
      "mcp-servers.json",
      "config.json",
      ".env",
      "!node_modules/**/darwin-*/**",
      "!node_modules/**/linux-*/**",
      "!node_modules/**/*-darwin-*/**",
      "!node_modules/**/*-linux-*/**",
      "!node_modules/**/*-arm64/**",
      "!node_modules/**/*-linux/**",
      "!node_modules/**/*-darwin/**"
    ],
    "asarUnpack": [
      "python-servers/**/*",
      "mcp-servers.json",
      "dist/main/mcp/**/*",
      "node_modules/@modelcontextprotocol/**/*",
      "node_modules/zod/**/*",
      "node_modules/zod-to-json-schema/**/*",
      "node_modules/ajv/**/*",
      "node_modules/cross-spawn/**/*",
      "node_modules/content-type/**/*",
      "node_modules/cors/**/*",
      "node_modules/eventsource/**/*",
      "node_modules/eventsource-parser/**/*",
      "node_modules/express/**/*",
      "node_modules/express-rate-limit/**/*",
      "node_modules/pkce-challenge/**/*",
      "node_modules/raw-body/**/*",
      "node_modules/isexe/**/*",
      "node_modules/path-key/**/*",
      "node_modules/shebang-command/**/*",
      "node_modules/shebang-regex/**/*",
      "node_modules/which/**/*",
      "node_modules/json-schema-traverse/**/*",
      "node_modules/fast-deep-equal/**/*",
      "node_modules/fast-json-stable-stringify/**/*",
      "node_modules/uri-js/**/*",
      "node_modules/punycode/**/*",
      "node_modules/vary/**/*",
      "node_modules/object-assign/**/*",
      "node_modules/cookie/**/*",
      "node_modules/cookie-signature/**/*",
      "node_modules/encodeurl/**/*",
      "node_modules/escape-html/**/*",
      "node_modules/etag/**/*",
      "node_modules/fresh/**/*",
      "node_modules/merge-descriptors/**/*",
      "node_modules/methods/**/*",
      "node_modules/on-finished/**/*",
      "node_modules/parseurl/**/*",
      "node_modules/path-to-regexp/**/*",
      "node_modules/proxy-addr/**/*",
      "node_modules/qs/**/*",
      "node_modules/range-parser/**/*",
      "node_modules/safe-buffer/**/*",
      "node_modules/send/**/*",
      "node_modules/serve-static/**/*",
      "node_modules/setprototypeof/**/*",
      "node_modules/statuses/**/*",
      "node_modules/type-is/**/*",
      "node_modules/utils-merge/**/*",
      "node_modules/ee-first/**/*",
      "node_modules/forwarded/**/*",
      "node_modules/ipaddr.js/**/*",
      "node_modules/side-channel/**/*",
      "node_modules/call-bind/**/*",
      "node_modules/get-intrinsic/**/*",
      "node_modules/es-define-property/**/*",
      "node_modules/es-errors/**/*",
      "node_modules/function-bind/**/*",
      "node_modules/gopd/**/*",
      "node_modules/has-property-descriptors/**/*",
      "node_modules/has-proto/**/*",
      "node_modules/has-symbols/**/*",
      "node_modules/hasown/**/*",
      "node_modules/object-inspect/**/*",
      "node_modules/set-function-length/**/*",
      "node_modules/define-data-property/**/*",
      "node_modules/ms/**/*",
      "node_modules/debug/**/*",
      "node_modules/mime/**/*",
      "node_modules/mime-types/**/*",
      "node_modules/mime-db/**/*",
      "node_modules/media-typer/**/*",
      "node_modules/bytes/**/*",
      "node_modules/http-errors/**/*",
      "node_modules/iconv-lite/**/*",
      "node_modules/unpipe/**/*",
      "node_modules/inherits/**/*",
      "node_modules/toidentifier/**/*",
      "node_modules/safer-buffer/**/*",
      "node_modules/destroy/**/*",
      "node_modules/body-parser/**/*",
      "node_modules/depd/**/*",
      "node_modules/express-session/**/*",
      "node_modules/finalhandler/**/*"
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico",
      "license": "build/license.txt",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "RSInsight Desktop",
      "perMachine": true,
      "allowElevation": true,
      "include": "build/installer.nsh"
    },
    "linux": {
      "icon": "build/icons/512x512.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@heroui/react": "^2.8.4",
    "@modelcontextprotocol/sdk": "^1.19.1",
    "@tailwindcss/postcss": "^4.1.14",
    "autoprefixer": "^10.4.21",
    "axios": "^1.12.2",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.7.3",
    "framer-motion": "^12.23.22",
    "jwt-decode": "^4.0.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "process": "^0.11.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.14",
    "ws": "^8.18.3"
  }
}
